# ==========================================
# Backend Configuration (.env for development)
# Copy this file to .env and modify values
# ==========================================

# Database
# SQLite (development default)
DATABASE_URL=sqlite:///./bookings.db
# PostgreSQL (production example):
# DATABASE_URL=postgresql://user:password@localhost:5432/bookings

# Server Configuration
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# CORS - Comma-separated list of allowed origins
# For development: * allows all origins (NOT for production!)
ALLOWED_ORIGINS=*
# For production, specify exact domains:
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# API Configuration
API_VERSION=1.0.0
API_PREFIX=/api/v1
API_TITLE=Booking API
API_DESCRIPTION=API для записи на звонок
